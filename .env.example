# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=rootroot
MYSQL_DATABASE=hr_recruitmentdb
MYSQL_PORT=3306

# OpenRouter — CV/job AI analysis (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Model id from https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Optional — recommended for OpenRouter rankings
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=ai-recruit-pro
# Set to "true" only if the model supports OpenAI-style json_object mode
OPENROUTER_JSON_MODE=false

APP_URL=http://localhost:3000

# Firebase (optional — client)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
